# Shared output paths.
AGENTIC_MM_RAG_DOC_ROOT=./data/doc_rag
AGENTIC_MM_RAG_VIDEO_ROOT=./data/video_rag
AGENTIC_MM_RAG_DOC_VISUAL_ASSET_ROOTS=./data/doc_parse

# RAG-Anything document ingestion.
# PARSER: mineru, docling, or paddleocr.
PARSER=mineru
# PARSE_METHOD: auto, ocr, or txt.
PARSE_METHOD=auto
MAX_CONCURRENT_FILES=1

# OpenAI-compatible model endpoint used by RAG-Anything.
OPENAI_API_KEY=
OPENAI_BASE_URL=
RAGANYTHING_LLM_MODEL=gpt-4o-mini
RAGANYTHING_VISION_MODEL=gpt-4o-mini
RAGANYTHING_EMBEDDING_MODEL=text-embedding-3-small
RAGANYTHING_EMBEDDING_DIM=1536
RAGANYTHING_EMBEDDING_MAX_TOKENS=8192

# VideoRAG ingestion.
# VIDEORAG_LLM_CONFIG: openai, openai-mini, azure-openai, ollama, or deepseek-bge.
VIDEORAG_LLM_CONFIG=openai-mini
VIDEORAG_SEGMENT_LENGTH=30
VIDEORAG_ROUGH_FRAMES=5
VIDEORAG_FINE_FRAMES=15
VIDEORAG_SEGMENT_TOP_K=4
VIDEORAG_VIDEO_BATCH_SIZE=2

# VideoRAG provider credentials. Fill only the provider you use.
# openai/openai-mini use OPENAI_API_KEY.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
OLLAMA_HOST=http://127.0.0.1:11434
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
